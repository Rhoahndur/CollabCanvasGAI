# Firebase Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env.local
# 2. Replace all "your_*" placeholders with your actual Firebase config values
# 3. Get these values from: Firebase Console > Project Settings > Your apps
# 
# Command to copy:
# cp env.template .env.local
#
# WARNING: Never commit .env.local to git! It's already in .gitignore

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Canny AI / OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
AI_QUOTA_PER_MINUTE=20

# Firebase Admin for server-side auth verification and durable AI quotas.
# Required in production for /api/chat.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@your_project_id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Local-only fallback if Firebase Admin quota storage is unavailable.
# Do not enable this in production.
ALLOW_IN_MEMORY_AI_QUOTA_FALLBACK=false
