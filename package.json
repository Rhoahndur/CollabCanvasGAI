{
  "name": "collabcanvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:all": "npm run server & npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:database:rules": "firebase deploy --only database",
    "deploy:vercel": "vercel --prod",
    "lint": "eslint src/ api/",
    "lint:fix": "eslint src/ api/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\" \"api/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\" \"api/**/*.js\"",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "api/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "0.0.66",
    "ai": "3.4.33",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "firebase": "^10.13.0",
    "openai": "^4.77.0",
    "openai-edge": "^1.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "jsdom": "^23.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "terser": "^5.44.0",
    "vite": "^5.4.2",
    "vitest": "^1.6.1"
  }
}
